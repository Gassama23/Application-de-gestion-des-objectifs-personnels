# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*

# End of https://mrkandreev.name/snippets/gitignore-generator/#Java

# Ignorer le dossier database
database/

# Ignorer le dossier lib
lib/

# Ignorer tous les fichiers .md à la racine du projet
/*.md

# Mais garder le README.md principal
!README.md

# Ignorer les scripts de nettoyage et téléchargement
nettoyer-git.ps1
nettoyer-git.sh
download-mysql-driver.ps1
download-mysql-driver.sh

# Ignorer les fichiers de test
src/org/odk/MainTest.java
src/org/odk/MainTestService.java
src/org/odk/TestEmailExiste.java
src/org/odk/TestConnexion.java
